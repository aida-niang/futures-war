        result = moderator.moderate(text)
        return result
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/enrich")
async def enrich_text(text: str, style: str = "futuristic"):
    """Prompt enrichment endpoint"""
    try:
        result = engineer.enrich(text, style)
        return result
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
